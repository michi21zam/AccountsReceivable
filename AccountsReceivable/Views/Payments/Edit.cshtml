@model AccountsReceivable.Models.Payment

@{
    ViewBag.Title = "Edit Payment";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Details", "Receivables", new { id = Model.ReceivableId })">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Payments</div>
        <h1 class="page-title"><span>Edit</span> payment</h1>
    </div>
    <div class="header-spacer"></div>
</div>

@using (Html.BeginForm("Edit", "Payments", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.PaymentId)
    @Html.HiddenFor(m => m.ReceivableId)

    <div class="form-page-card">
        <div class="form-page-header">
            <i class="fa fa-circle-info"></i> Payment Information
        </div>

        @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

        <div class="form-row-grid">
            <div class="float-field">
                <label>Payment Date</label>
                @Html.TextBoxFor(m => m.PaymentDate, "{0:yyyy-MM-dd}", new { @class = "float-input", type = "date" })
                @Html.ValidationMessageFor(m => m.PaymentDate, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Amount</label>
                @Html.TextBoxFor(m => m.Amount, new { @class = "float-input", type = "number", step = "0.01", placeholder = " " })
                @Html.ValidationMessageFor(m => m.Amount, "", new { @class = "field-error" })
            </div>
            <div class="float-field grid-span-2">
                <label>Notes</label>
                @Html.TextBoxFor(m => m.Notes, new { @class = "float-input", placeholder = " " })
            </div>
        </div>

        <div class="form-page-actions">
            <button type="submit" class="btn-create">
                <i class="fa fa-floppy-disk"></i> SAVE
            </button>
            <a href="@Url.Action("Details", "Receivables", new { id = Model.ReceivableId })" class="btn-back ml-10">
                Cancel
            </a>
        </div>
    </div>
}
