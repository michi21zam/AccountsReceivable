@model AccountsReceivable.Models.Payment

@{
    ViewBag.Title = "Add Payment";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a class="btn btn-info" href="@Url.Action("Details", "Receivables", new { id = Model.ReceivableId })">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="text-center flex-grow-1">
        <div class="text-muted text-uppercase small fw-bold" style="letter-spacing: 2px;">Payments</div>
        <h1 class="h3 fw-bold"><span style="color: #0b5566;">Add</span> new payment</h1>
    </div>
    <div style="min-width: 100px;"></div>
</div>

@using (Html.BeginForm("Create", "Payments", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ReceivableId)

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 text-uppercase fw-bold" style="color: #0b5566; letter-spacing: 1px; font-size: 13px;">
                <i class="fa fa-circle-info"></i> Payment Information
            </h5>
        </div>
        <div class="card-body">
            @if (ViewData.ModelState.Count > 0 && !ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @Html.ValidationSummary(false)
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="row g-3">
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Payment Date</label>
                    @Html.TextBoxFor(m => m.PaymentDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.PaymentDate, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Amount</label>
                    @Html.TextBoxFor(m => m.Amount, new { @class = "form-control", type = "number", step = "0.01", placeholder = "0.00" })
                    @Html.ValidationMessageFor(m => m.Amount, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                <div class="col-lg-6">
                    <label class="form-label small fw-bold text-muted text-uppercase">Notes</label>
                    @Html.TextBoxFor(m => m.Notes, new { @class = "form-control", placeholder = " " })
                </div>
            </div>
        </div>
        <div class="card-footer bg-white border-top">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="fa fa-floppy-disk"></i> SAVE
                </button>
                <a href="@Url.Action("Details", "Receivables", new { id = Model.ReceivableId })" class="btn btn-secondary">
                    Cancel
                </a>
            </div>
        </div>
    </div>
}