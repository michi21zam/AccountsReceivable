@model AccountsReceivable.Models.Payment

@{
    ViewBag.Title = "Delete Payment";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Details", "Receivables", new { id = Model.ReceivableId })">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Payments</div>
        <h1 class="page-title page-title--danger"><span>Delete</span> payment?</h1>
    </div>
    <div class="header-spacer"></div>
</div>

<div class="form-page-card form-page-card--danger">
    <div class="form-page-header form-page-header--danger">
        <i class="fa fa-triangle-exclamation"></i> Confirm Deletion
    </div>
    <p class="muted-lead">
        Are you sure you want to delete this payment? This action cannot be undone.
    </p>

    <div class="form-row-grid">
        <div class="float-field">
            <label>Payment Date</label>
            <input class="float-input" value="@Model.PaymentDate.ToString("MMM dd, yyyy")" readonly />
        </div>
        <div class="float-field">
            <label>Amount</label>
            <input class="float-input" value="@String.Format("{0:C}", Model.Amount)" readonly />
        </div>
        <div class="float-field grid-span-2">
            <label>Notes</label>
            <input class="float-input" value="@Model.Notes" readonly />
        </div>
    </div>

    @using (Html.BeginForm("Delete", "Payments", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.PaymentId)
        <div class="form-page-actions">
            <button type="submit" class="btn-create btn-create--danger">
                <i class="fa fa-trash"></i> YES, DELETE
            </button>
            <a href="@Url.Action("Details", "Receivables", new { id = Model.ReceivableId })" class="btn-back ml-10">
                Cancel
            </a>
        </div>
    }
</div>
