<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Accounts Receivable</title>

    <!-- Bootstrap CSS -->
    <link href="~/Content/bootstrap.css" rel="stylesheet" type="text/css" />

    <!-- Site CSS (después de Bootstrap para poder personalizar) -->
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />

    <!-- FontAwesome -->
    <link href="~/Content/fontawesome/fontawesome-local.css" rel="stylesheet" type="text/css" />

    <!-- Bootstrap Theme -->
    <link href="~/Content/bootstrap-theme.css" rel="stylesheet" type="text/css" />

    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='75' font-size='75' fill='%230b5566'>$</text></svg>" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
        <div class="container-fluid" style="max-width: 1200px; margin: 0 auto;">
            <a class="navbar-brand fw-bold" href="@Url.Action("Index","Receivables")">
                <i class="fa fa-file-invoice-dollar" style="color: #0b5566; margin-right: 8px;"></i>Accounts Receivable
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-3">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index","Receivables")">
                            <i class="fa fa-file-invoice" style="margin-right: 6px;"></i>Receivables
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index","Customers")">
                            <i class="fa fa-users" style="margin-right: 6px;"></i>Customers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index","Employees")">
                            <i class="fa fa-user-tie" style="margin-right: 6px;"></i>Employees
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid" style="max-width: 1200px; margin: 0 auto; padding: 32px 24px 60px;">
        @RenderBody()
        <footer class="text-center text-muted small border-top mt-5 pt-3">
            <p>&copy; @DateTime.Now.Year &mdash; Accounts Receivable &mdash; All rights reserved</p>
        </footer>
    </div>

    <!-- Bootstrap JS -->
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
</body>
</html>