@using AccountsReceivable.Resources
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - @Lang.T("BrandTitle")</title>

    <!-- Bootstrap 5 (CDN, no build step needed) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Your small theme override on top -->
    <link href="~/Content/bootstrap-theme.css" rel="stylesheet" type="text/css" />
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="@Url.Action("Index", "Receivables")">
                <i class="bi bi-receipt"></i> @Lang.T("BrandTitle")
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-3 gap-2">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Receivables")">
                            <i class="bi bi-file-earmark-text"></i> @Lang.T("NavReceivables")
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Customers")">
                            <i class="bi bi-people"></i> @Lang.T("NavCustomers")
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Employees")">
                            <i class="bi bi-person-badge"></i> @Lang.T("NavEmployees")
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="langDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-globe"></i> @(Lang.CurrentLang == "es" ? @Lang.T("LanguageSpanish") : @Lang.T("LanguageEnglish"))
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="langDropdown">
                            <li>
                                <a class="dropdown-item @(Lang.CurrentLang == "en" ? "active" : "")"
                                   href="@Url.Action("SetLanguage", "Language", new { lang = "en", returnUrl = Request.Url.PathAndQuery })">
                                    @Lang.T("LanguageEnglish")
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item @(Lang.CurrentLang == "es" ? "active" : "")"
                                   href="@Url.Action("SetLanguage", "Language", new { lang = "es", returnUrl = Request.Url.PathAndQuery })">
                                    @Lang.T("LanguageSpanish")
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        @RenderBody()
        <footer class="text-center text-muted small border-top pt-3 mt-4">
            <p>&copy; @DateTime.Now.Year &mdash; @Lang.T("BrandTitle") &mdash; @Lang.T("Footer")</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Delete Confirmation Modal (reutilizable en todo el sitio) -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle"></i> @Lang.T("ConfirmDeletion")</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @Lang.T("ConfirmDeleteGenericText")
                </div>
                <form id="deleteForm" method="post" action="" class="modal-footer">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@Lang.T("Cancel")</button>
                    <button type="submit" class="btn btn-danger fw-bold"><i class="bi bi-trash"></i> @Lang.T("YesDelete")</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        (function () {
            var deleteModalEl = document.getElementById('deleteModal');
            var deleteModal = new bootstrap.Modal(deleteModalEl);
            var deleteForm = document.getElementById('deleteForm');

            document.addEventListener('click', function (e) {
                var btn = e.target.closest('.js-delete-trigger');
                if (btn) {
                    e.preventDefault();
                    deleteForm.setAttribute('action', btn.getAttribute('data-delete-url'));
                    deleteModal.show();
                }
            });
        })();
    </script>
</body>
</html>
