@model AccountsReceivable.Models.ReceivableIndexViewModel
@using AccountsReceivable.Models

@{
    ViewBag.Title = "Accounts Receivable";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a class="btn btn-success btn-lg" href="@Url.Action("Create", "Receivables")">
                <i class="fa fa-plus"></i> CREATE NEW
            </a>
        </div>
        <div class="text-center">
            <div class="text-muted text-uppercase small fw-bold" style="letter-spacing: 2px;">Accounts Receivable</div>
            <h1 class="h2 fw-bold" style="color: #223344;"><span style="color: #0b5566;">Review</span> accounts receivable</h1>
        </div>
        <div style="min-width: 120px;"></div>
    </div>
</div>

@using (Html.BeginForm("Index", "Receivables", FormMethod.Get, new { @class = "mb-4" }))
{
    <div class="card border-0 shadow-sm p-4 mb-4">
        <div class="row g-3">
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Account Number</label>
                @Html.TextBoxFor(m => m.AccountNumber, new { @class = "form-control", placeholder = "AR-001" })
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Customer</label>
                @Html.DropDownListFor(m => m.CustomerId,
                         new SelectList(Model.Customers, "CustomerId", "Name", Model.CustomerId),
                         "All customers",
                         new { @class = "form-select" })
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Employee</label>
                @Html.DropDownListFor(m => m.EmployeeId,
                         new SelectList(Model.Employees, "EmployeeId", "FirstName", Model.EmployeeId),
                         "All employees",
                         new { @class = "form-select" })
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Status</label>
                @Html.DropDownListFor(m => m.Status,
                         new SelectList(Enum.GetValues(typeof(ReceivableStatus))),
                         "All statuses",
                         new { @class = "form-select" })
            </div>

            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Date From</label>
                @Html.TextBoxFor(m => m.DateFrom, "{0:yyyy-MM-dd}", new { @type = "date", @class = "form-control" })
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Date To</label>
                @Html.TextBoxFor(m => m.DateTo, "{0:yyyy-MM-dd}", new { @type = "date", @class = "form-control" })
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Amount From</label>
                @Html.TextBoxFor(m => m.AmountFrom, new { @type = "number", @step = "0.01", @class = "form-control", placeholder = "0.00" })
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Amount To</label>
                @Html.TextBoxFor(m => m.AmountTo, new { @type = "number", @step = "0.01", @class = "form-control", placeholder = "0.00" })
            </div>

            <div class="col-12">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" title="Search">
                        <i class="fa fa-search"></i> Search
                    </button>
                    <a href="@Url.Action("Index", "Receivables")" class="btn btn-secondary" title="Reset">
                        <i class="fa fa-rotate-right"></i> Reset
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Account #</th>
                    <th>Customer</th>
                    <th>Employee</th>
                    <th>Issue Date</th>
                    <th>Due Date</th>
                    <th>Total</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Receivables != null && Model.Receivables.Any())
                {
                    foreach (var item in Model.Receivables)
                    {
                        <tr>
                            <td>@item.AccountNumber</td>
                            <td>@item.CustomerName</td>
                            <td>@item.EmployeeName</td>
                            <td>@item.IssueDate.ToString("MMM dd, yyyy")</td>
                            <td>@item.DueDate.ToString("MMM dd, yyyy")</td>
                            <td>@String.Format("{0:C}", item.TotalAmount)</td>
                            <td>@String.Format("{0:C}", item.Balance)</td>
                            <td>
                                @if (item.Status == ReceivableStatus.Paid)
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                                else if (item.Status == ReceivableStatus.PartiallyPaid)
                                {
                                    <span class="badge bg-info">Partially Paid</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                            </td>
                            <td class="text-center">
                                <a class="btn btn-sm btn-info" href="@Url.Action("Details", "Receivables", new { id = item.ReceivableId })" title="Details">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a class="btn btn-sm btn-warning" href="@Url.Action("Edit", "Receivables", new { id = item.ReceivableId })" title="Edit">
                                    <i class="fa fa-pen"></i>
                                </a>
                                @using (Html.BeginForm("Delete", "Receivables", FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Delete this receivable?');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", item.ReceivableId)
                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-5 text-muted">
                            <i class="fa fa-file-invoice" style="font-size: 36px; opacity: .35; display: block; margin-bottom: 12px;"></i>
                            No accounts receivable found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @{
        Func<int, string> pageUrl = p => Url.Action("Index", new
        {
            page = p,
            pageSize = Model.PageSize,
            accountNumber = Model.AccountNumber,
            customerId = Model.CustomerId,
            employeeId = Model.EmployeeId,
            status = Model.Status,
            dateFrom = Model.DateFrom != null ? Model.DateFrom.Value.ToString("yyyy-MM-dd") : null,
            dateTo = Model.DateTo != null ? Model.DateTo.Value.ToString("yyyy-MM-dd") : null,
            amountFrom = Model.AmountFrom,
            amountTo = Model.AmountTo
        });
    }

    <nav class="d-flex justify-content-center align-items-center mt-4 mb-3">
        <ul class="pagination mb-0 gap-2">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" href="@(Model.Page > 1 ? pageUrl(1) : "#")">
                    <i class="fa fa-angles-left"></i>
                </a>
            </li>
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" href="@(Model.Page > 1 ? pageUrl(Model.Page - 1) : "#")">
                    <i class="fa fa-angle-left"></i>
                </a>
            </li>
            @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link" href="@pageUrl(p)">@p</a>
                </li>
            }
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@(Model.Page < Model.TotalPages ? pageUrl(Model.Page + 1) : "#")">
                    <i class="fa fa-angle-right"></i>
                </a>
            </li>
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@(Model.Page < Model.TotalPages ? pageUrl(Model.TotalPages) : "#")">
                    <i class="fa fa-angles-right"></i>
                </a>
            </li>
        </ul>
    </nav>
    <p class="text-center text-muted small mb-4">
        Page @Model.Page of @(Model.TotalPages == 0 ? 1 : Model.TotalPages) &mdash; @Model.TotalCount record(s)
    </p>
</div>