@using AccountsReceivable.Resources
@model AccountsReceivable.Models.ReceivableIndexViewModel
@using AccountsReceivable.Models

@{
    ViewBag.Title = Lang.T("BrandTitle");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-success fw-bold" href="@Url.Action("Create", "Receivables")">
        <i class="bi bi-plus-lg"></i> @Lang.T("CreateNew")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">@Lang.T("LabelAR")</div>
        <h1 class="page-title h3 fw-bold m-0">@Lang.T("TitleReviewReceivables")</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

@using (Html.BeginForm("Index", "Receivables", FormMethod.Get))
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label form-label-sm">@Lang.T("FieldAccountNumber")</label>
                    @Html.TextBoxFor(m => m.AccountNumber, new { @class = "form-control", placeholder = "AR-001" })
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm">@Lang.T("FieldCustomer")</label>
                    @Html.DropDownListFor(m => m.CustomerId,
                        new SelectList(Model.Customers, "CustomerId", "Name", Model.CustomerId), Lang.T("AllCustomers"), new { @class = "form-select" })
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm">@Lang.T("FieldEmployee")</label>
                    @Html.DropDownListFor(m => m.EmployeeId,
                        new SelectList(Model.Employees, "EmployeeId", "FirstName", Model.EmployeeId), Lang.T("AllEmployees"), new { @class = "form-select" })
                </div>
                <div class="col-md-1">
                    <label class="form-label form-label-sm">@Lang.T("FieldStatus")</label>
                    @Html.DropDownListFor(m => m.Status,
                        new SelectList(Enum.GetValues(typeof(ReceivableStatus))), Lang.T("All"), new { @class = "form-select" })
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm">@Lang.T("FieldDateFrom")</label>
                    @Html.TextBoxFor(m => m.DateFrom, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm">@Lang.T("FieldDateTo")</label>
                    @Html.TextBoxFor(m => m.DateTo, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                </div>
                <div class="col-md-1 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-action" title="Search">
                        <i class="bi bi-search"></i>
                    </button>
                    <a href="@Url.Action("Index", "Receivables")" class="btn btn-secondary btn-action" title="Reset">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>@Lang.T("ColAccountNum")</th>
                    <th>@Lang.T("FieldCustomer")</th>
                    <th>@Lang.T("FieldEmployee")</th>
                    <th>@Lang.T("FieldIssueDate")</th>
                    <th>@Lang.T("FieldDueDate")</th>
                    <th>@Lang.T("FieldTotalAmount")</th>
                    <th>@Lang.T("FieldStatus")</th>
                    <th class="text-center">@Lang.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Receivables.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <i class="bi bi-inbox d-block fs-1 opacity-25 mb-2"></i>
                            @Lang.T("NoReceivablesFound")
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Receivables)
                    {
                        <tr>
                            <td>@item.AccountNumber</td>
                            <td>@item.CustomerName</td>
                            <td>@item.EmployeeName</td>
                            <td>@item.IssueDate.ToShortDateString()</td>
                            <td>@item.DueDate.ToShortDateString()</td>
                            <td>@item.TotalAmount.ToString("C")</td>
                            <td>
                                @{
                                    // map each ReceivableStatus value to a badge color class
                                    string badgeClass;
                                    if (item.Status == ReceivableStatus.Paid) { badgeClass = "bg-status-active"; }
                                    else if (item.Status == ReceivableStatus.Pending) { badgeClass = "bg-status-pending"; }
                                    else if (item.Status == ReceivableStatus.PartiallyPaid) { badgeClass = "bg-status-partial"; }
                                    else { badgeClass = "bg-status-inactive"; }
                                }
                                <span class="badge rounded-pill @badgeClass">@item.Status</span>
                            </td>
                            <td class="text-center">
                                <a href="@Url.Action("Details", "Receivables", new { id = item.ReceivableId })"
                                   class="btn btn-primary btn-action" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="@Url.Action("Edit", "Receivables", new { id = item.ReceivableId })"
                                   class="btn btn-warning btn-action" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="@Url.Action("Delete", "Receivables", new { id = item.ReceivableId })"
                                   class="btn btn-danger btn-action js-delete-trigger"
                                   data-delete-url="@Url.Action("Delete", "Receivables", new { id = item.ReceivableId })"
                                   title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
