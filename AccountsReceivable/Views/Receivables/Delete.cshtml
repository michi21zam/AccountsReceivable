@model AccountsReceivable.Models.Receivable

@{
    ViewBag.Title = "Delete Receivable";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Receivables")">
        <i class="bi bi-arrow-left"></i> BACK
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label text-danger">Accounts Receivable</div>
        <h1 class="h3 fw-bold m-0 text-danger"><span>Delete</span> receivable?</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

<div class="card border-top border-danger border-3">
    <div class="card-header bg-white">
        <span class="card-header-title text-danger"><i class="bi bi-exclamation-triangle"></i> Confirm Deletion</span>
    </div>
    <div class="card-body">
        <p class="text-muted mb-4">
            Are you sure you want to delete the following receivable? This action cannot be undone.
        </p>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label form-label-sm">Account Number</label>
                <input class="form-control" value="@Model.AccountNumber" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm">Customer</label>
                <input class="form-control" value="@Model.Customer?.Name" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm">Total Amount</label>
                <input class="form-control" value="@String.Format("{0:C}", Model.TotalAmount)" readonly />
            </div>
        </div>

        @using (Html.BeginForm("Delete", "Receivables", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.ReceivableId)
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-danger fw-bold">
                    <i class="bi bi-trash"></i> YES, DELETE
                </button>
                <a href="@Url.Action("Index", "Receivables")" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        }
    </div>
</div>
