@model AccountsReceivable.Models.Receivable
@using AccountsReceivable.Models

@{
    ViewBag.Title = "Edit Receivable";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Index", "Receivables")">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Accounts Receivable</div>
        <h1 class="page-title"><span>Edit</span> receivable settings</h1>
    </div>
    <div class="header-spacer"></div>
</div>

@using (Html.BeginForm("Edit", "Receivables", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ReceivableId)

    <div class="form-page-card">
        <div class="form-page-header">
            <i class="fa fa-circle-info"></i> Receivable Information
        </div>

        @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

        <div class="form-row-grid">
            <div class="float-field">
                <label>Account Number</label>
                @Html.TextBoxFor(m => m.AccountNumber, new { @class = "float-input", placeholder = " " })
                @Html.ValidationMessageFor(m => m.AccountNumber, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Customer</label>
                @Html.DropDownListFor(m => m.CustomerId,
                         new SelectList((IEnumerable<Customer>)ViewBag.Customers, "CustomerId", "Name", Model.CustomerId),
                         new { @class = "float-select" })
                @Html.ValidationMessageFor(m => m.CustomerId, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Employee</label>
                @Html.DropDownListFor(m => m.EmployeeId,
                         new SelectList((IEnumerable<Employee>)ViewBag.Employees, "EmployeeId", "FirstName", Model.EmployeeId),
                         new { @class = "float-select" })
                @Html.ValidationMessageFor(m => m.EmployeeId, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Issue Date</label>
                @Html.TextBoxFor(m => m.IssueDate, "{0:yyyy-MM-dd}", new { @class = "float-input", type = "date" })
                @Html.ValidationMessageFor(m => m.IssueDate, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Due Date</label>
                @Html.TextBoxFor(m => m.DueDate, "{0:yyyy-MM-dd}", new { @class = "float-input", type = "date" })
                @Html.ValidationMessageFor(m => m.DueDate, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Total Amount</label>
                @Html.TextBoxFor(m => m.TotalAmount, new { @class = "float-input", type = "number", step = "0.01", placeholder = " " })
                @Html.ValidationMessageFor(m => m.TotalAmount, "", new { @class = "field-error" })
            </div>
            <div class="float-field grid-span-2">
                <label>Description</label>
                @Html.TextBoxFor(m => m.Description, new { @class = "float-input", placeholder = " " })
            </div>
        </div>

        <div class="form-page-actions">
            <button type="submit" class="btn-create">
                <i class="fa fa-floppy-disk"></i> SAVE
            </button>
            <a href="@Url.Action("Details", "Receivables", new { id = Model.ReceivableId })" class="btn-back ml-10">
                Cancel
            </a>
        </div>
    </div>
}

@* ── PAYMENTS TABLE ────────────────────────────────── *@
<div class="page-header-section page-header-section--compact">
    <div>
        <a class="btn-create btn-create--compact" href="@Url.Action("Create", "Payments", new { receivableId = Model.ReceivableId })">
            <i class="fa fa-plus"></i> ADD PAYMENT
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Payments</div>
        <h2 class="page-title page-title--small">Payment <span>History</span></h2>
    </div>
</div>

<div class="table-card">
    <table>
        <thead>
            <tr>
                <th>Payment Date</th>
                <th>Amount</th>
                <th>Notes</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Payments != null && Model.Payments.Any(p => p.IsActive))
            {
                foreach (var payment in Model.Payments.Where(p => p.IsActive).OrderByDescending(p => p.PaymentDate))
                {
                    <tr>
                        <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                        <td>@String.Format("{0:C}", payment.Amount)</td>
                        <td>@payment.Notes</td>
                        <td class="text-center">
                            <a class="action-btn action-edit"
                               href="@Url.Action("Edit", "Payments", new { id = payment.PaymentId })"
                               title="Edit">
                                <i class="fa fa-pen"></i>
                            </a>
                            @using (Html.BeginForm("Delete", "Payments", FormMethod.Post,
                                new { @class = "inline-form", onsubmit = "return confirm('Delete this payment?');" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("id", payment.PaymentId)
                                <button type="submit" class="action-btn action-delete" title="Delete">
                                    <i class="fa fa-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="no-data-cell">
                        <i class="fa fa-hand-holding-dollar no-data-icon"></i>
                        No payments recorded yet.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

