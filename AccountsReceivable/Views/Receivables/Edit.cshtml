@using AccountsReceivable.Resources
@model AccountsReceivable.Models.Receivable
@using AccountsReceivable.Models

@{
    ViewBag.Title = Lang.T("TitleEditReceivable");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Receivables")">
        <i class="bi bi-arrow-left"></i> @Lang.T("Back")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">@Lang.T("LabelAR")</div>
        <h1 class="h3 fw-bold m-0">@Lang.T("TitleEditReceivable")</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

@using (Html.BeginForm("Edit", "Receivables", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ReceivableId)

    <div class="card mb-4">
        <div class="card-header bg-white">
            <span class="card-header-title"><i class="bi bi-info-circle"></i> @Lang.T("SectionReceivableInfo")</span>
        </div>
        <div class="card-body">

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2" })

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldAccountNumber")</label>
                    @Html.TextBoxFor(m => m.AccountNumber, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.AccountNumber, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldCustomer")</label>
                    @Html.DropDownListFor(m => m.CustomerId,
                        new SelectList((IEnumerable<Customer>)ViewBag.Customers, "CustomerId", "Name", Model.CustomerId),
                        new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.CustomerId, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldEmployee")</label>
                    @Html.DropDownListFor(m => m.EmployeeId,
                        new SelectList((IEnumerable<Employee>)ViewBag.Employees, "EmployeeId", "FirstName", Model.EmployeeId),
                        new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.EmployeeId, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldIssueDate")</label>
                    @Html.TextBoxFor(m => m.IssueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.IssueDate, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldDueDate")</label>
                    @Html.TextBoxFor(m => m.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.DueDate, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldTotalAmount")</label>
                    @Html.TextBoxFor(m => m.TotalAmount, new { @class = "form-control", type = "number", step = "0.01" })
                    @Html.ValidationMessageFor(m => m.TotalAmount, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">@Lang.T("FieldDescription")</label>
                    @Html.TextBoxFor(m => m.Description, new { @class = "form-control" })
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success fw-bold">
                    <i class="bi bi-save"></i> @Lang.T("Save")
                </button>
                <a href="@Url.Action("Details", "Receivables", new { id = Model.ReceivableId })" class="btn btn-outline-secondary">
                    @Lang.T("Cancel")
                </a>
            </div>
        </div>
    </div>
}

@* ── PAYMENTS TABLE ────────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between mb-3">
    <a class="btn btn-success btn-sm fw-bold" href="@Url.Action("Create", "Payments", new { receivableId = Model.ReceivableId })">
        <i class="bi bi-plus-lg"></i> @Lang.T("AddPayment")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">@Lang.T("LabelPayments")</div>
        <h2 class="h5 fw-bold m-0">@Lang.T("PaymentHistoryTitle")</h2>
    </div>
    <div style="min-width:140px;"></div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>@Lang.T("FieldPaymentDate")</th>
                    <th>@Lang.T("FieldAmount")</th>
                    <th>@Lang.T("FieldNotes")</th>
                    <th class="text-center">@Lang.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Payments != null && Model.Payments.Any(p => p.IsActive))
                {
                    foreach (var payment in Model.Payments.Where(p => p.IsActive).OrderByDescending(p => p.PaymentDate))
                    {
                        <tr>
                            <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                            <td>@String.Format("{0:C}", payment.Amount)</td>
                            <td>@payment.Notes</td>
                            <td class="text-center">
                                <a class="btn btn-warning btn-action" href="@Url.Action("Edit", "Payments", new { id = payment.PaymentId })" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @using (Html.BeginForm("Delete", "Payments", FormMethod.Post,
                                    new { @class = "d-inline", onsubmit = "return confirm('" + Lang.T("ConfirmDeletePaymentJs") + "');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", payment.PaymentId)
                                    <button type="submit" class="btn btn-danger btn-action" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-cash-coin d-block fs-1 opacity-25 mb-2"></i>
                            @Lang.T("NoPaymentsRecorded")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
