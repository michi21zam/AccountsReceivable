@using AccountsReceivable.Resources
@model AccountsReceivable.Models.ReceivableDetailsViewModel

@{
    ViewBag.Title = Lang.T("TitleReceivableDetails");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Receivables")">
        <i class="bi bi-arrow-left"></i> @Lang.T("Back")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">@Lang.T("LabelAR")</div>
        <h1 class="h3 fw-bold m-0">@Lang.T("TitleReceivableDetails")@Model.AccountNumber</h1>
    </div>
    <div style="min-width:140px; text-align:right;">
        <a class="btn btn-success btn-sm fw-bold" href="@Url.Action("Edit", "Receivables", new { id = Model.ReceivableId })">
            <i class="bi bi-pencil"></i> @Lang.T("Edit")
        </a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-white">
        <span class="card-header-title"><i class="bi bi-info-circle"></i> @Lang.T("SectionReceivableInfo")</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldAccountNumber")</label>
                <input class="form-control" value="@Model.AccountNumber" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldCustomer")</label>
                <input class="form-control" value="@Model.CustomerName" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldEmployee")</label>
                <input class="form-control" value="@Model.EmployeeName" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldIssueDate")</label>
                <input class="form-control" value="@Model.IssueDate.ToString("MMM dd, yyyy")" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldDueDate")</label>
                <input class="form-control" value="@Model.DueDate.ToString("MMM dd, yyyy")" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldTotalAmount")</label>
                <input class="form-control" value="@String.Format("{0:C}", Model.TotalAmount)" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldPaidAmount")</label>
                <input class="form-control" value="@String.Format("{0:C}", Model.PaidAmount)" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldBalance")</label>
                <input class="form-control" value="@String.Format("{0:C}", Model.Balance)" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldStatus")</label>
                <input class="form-control" value="@Model.Status" readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label form-label-sm">@Lang.T("FieldDescription")</label>
                <input class="form-control" value="@Model.Description" readonly />
            </div>
        </div>
    </div>
</div>

@* ── PAYMENTS TABLE ────────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between mb-3">
    <a class="btn btn-success btn-sm fw-bold" href="@Url.Action("Create", "Payments", new { receivableId = Model.ReceivableId })">
        <i class="bi bi-plus-lg"></i> @Lang.T("AddPayment")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">@Lang.T("LabelPayments")</div>
        <h2 class="h5 fw-bold m-0">@Lang.T("PaymentHistoryTitle")</h2>
    </div>
    <div style="min-width:140px;"></div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>@Lang.T("FieldPaymentDate")</th>
                    <th>@Lang.T("FieldAmount")</th>
                    <th>@Lang.T("FieldNotes")</th>
                    <th class="text-center">@Lang.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Payments != null && Model.Payments.Any(p => p.IsActive))
                {
                    foreach (var payment in Model.Payments.Where(p => p.IsActive).OrderByDescending(p => p.PaymentDate))
                    {
                        <tr>
                            <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                            <td>@String.Format("{0:C}", payment.Amount)</td>
                            <td>@payment.Notes</td>
                            <td class="text-center">
                                <a class="btn btn-primary btn-action" href="@Url.Action("Details", "Payments", new { id = payment.PaymentId })" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button" class="btn btn-warning btn-action" title="Edit" disabled>
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-danger btn-action" title="Delete" disabled>
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-cash-coin d-block fs-1 opacity-25 mb-2"></i>
                            @Lang.T("NoPaymentsRecorded")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
