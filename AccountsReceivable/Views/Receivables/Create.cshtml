@using AccountsReceivable.Resources
@model AccountsReceivable.Models.Receivable
@using AccountsReceivable.Models

@{
    ViewBag.Title = Lang.T("TitleCreateReceivable");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Receivables")">
        <i class="bi bi-arrow-left"></i> @Lang.T("Back")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">@Lang.T("LabelAR")</div>
        <h1 class="h3 fw-bold m-0">@Lang.T("TitleCreateReceivable")</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

@using (Html.BeginForm("Create", "Receivables", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="card">
        <div class="card-header bg-white">
            <span class="card-header-title"><i class="bi bi-info-circle"></i> @Lang.T("SectionReceivableInfo")</span>
        </div>
        <div class="card-body">

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2" })

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldAccountNumber")</label>
                    @Html.TextBoxFor(m => m.AccountNumber, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.AccountNumber, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldCustomer")</label>
                    <select id="CustomerId" name="CustomerId" class="form-select">
                        <option value="">@Lang.T("SelectCustomer")</option>
                        @foreach (var c in (IEnumerable<Customer>)ViewBag.Customers)
                        {
                            <option value="@c.CustomerId" data-credit-limit="@c.CreditLimit.ToString(System.Globalization.CultureInfo.InvariantCulture)">@c.Name</option>
                        }
                    </select>
                    @Html.ValidationMessageFor(m => m.CustomerId, "", new { @class = "text-danger small" })
                    <div id="creditLimitInfo" class="form-text"></div>
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldEmployee")</label>
                    @Html.DropDownListFor(m => m.EmployeeId,
                             new SelectList((IEnumerable<Employee>)ViewBag.Employees, "EmployeeId", "FirstName"),
                             Lang.T("SelectEmployee"), new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.EmployeeId, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldIssueDate")</label>
                    @Html.TextBoxFor(m => m.IssueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.IssueDate, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldDueDate")</label>
                    @Html.TextBoxFor(m => m.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.DueDate, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldTotalAmount")</label>
                    @Html.TextBoxFor(m => m.TotalAmount, new { @class = "form-control", type = "number", step = "0.01", id = "TotalAmount" })
                    @Html.ValidationMessageFor(m => m.TotalAmount, "", new { @class = "text-danger small" })
                    <div id="creditLimitError" class="text-danger small" style="display:none;"></div>
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">@Lang.T("FieldDescription")</label>
                    @Html.TextBoxFor(m => m.Description, new { @class = "form-control" })
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success fw-bold">
                    <i class="bi bi-save"></i> @Lang.T("Save")
                </button>
                <a href="@Url.Action("Index", "Receivables")" class="btn btn-outline-secondary">
                    @Lang.T("Cancel")
                </a>
            </div>
        </div>
    </div>
}

<script>
(function () {
    var customerSelect = document.getElementById("CustomerId");
    var totalAmountInput = document.getElementById("TotalAmount");
    var creditLimitInfo = document.getElementById("creditLimitInfo");
    var creditLimitError = document.getElementById("creditLimitError");
    var form = customerSelect.closest("form");

    var errorMsgTemplate = @Html.Raw(Json.Encode(Lang.T("ErrorExceedsCreditLimit")));
    var availableLabel = @Html.Raw(Json.Encode(Lang.T("AvailableCreditLimit")));

    function getCreditLimit() {
        var opt = customerSelect.options[customerSelect.selectedIndex];
        var val = opt ? opt.getAttribute("data-credit-limit") : null;
        return val ? parseFloat(val) : null;
    }

    function validate() {
        var limit = getCreditLimit();
        var amount = parseFloat(totalAmountInput.value);

        if (limit !== null) {
            creditLimitInfo.textContent = availableLabel + " " + limit.toFixed(2);
        } else {
            creditLimitInfo.textContent = "";
        }

        if (limit !== null && !isNaN(amount) && amount > limit) {
            creditLimitError.textContent = errorMsgTemplate.replace("{0}", limit.toFixed(2));
            creditLimitError.style.display = "block";
            totalAmountInput.setCustomValidity(creditLimitError.textContent);
            return false;
        }

        creditLimitError.style.display = "none";
        totalAmountInput.setCustomValidity("");
        return true;
    }

    customerSelect.addEventListener("change", validate);
    totalAmountInput.addEventListener("input", validate);

    form.addEventListener("submit", function (e) {
        if (!validate()) {
            e.preventDefault();
        }
    });
})();
</script>

