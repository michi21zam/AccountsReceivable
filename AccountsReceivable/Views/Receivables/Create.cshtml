@model AccountsReceivable.Models.Receivable
@using AccountsReceivable.Models

@{
    ViewBag.Title = "Create Receivable";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Receivables")">
        <i class="bi bi-arrow-left"></i> BACK
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">Accounts Receivable</div>
        <h1 class="h3 fw-bold m-0"><span>Create</span> new receivable</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

@using (Html.BeginForm("Create", "Receivables", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="card">
        <div class="card-header bg-white">
            <span class="card-header-title"><i class="bi bi-info-circle"></i> Receivable Information</span>
        </div>
        <div class="card-body">

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2" })

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Account Number</label>
                    @Html.TextBoxFor(m => m.AccountNumber, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.AccountNumber, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Customer</label>
                    @Html.DropDownListFor(m => m.CustomerId,
                        new SelectList((IEnumerable<Customer>)ViewBag.Customers, "CustomerId", "Name"),
                        "Select a customer", new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.CustomerId, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Employee</label>
                    @Html.DropDownListFor(m => m.EmployeeId,
                        new SelectList((IEnumerable<Employee>)ViewBag.Employees, "EmployeeId", "FirstName"),
                        "Select an employee", new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.EmployeeId, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Issue Date</label>
                    @Html.TextBoxFor(m => m.IssueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.IssueDate, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Due Date</label>
                    @Html.TextBoxFor(m => m.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.DueDate, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Total Amount</label>
                    @Html.TextBoxFor(m => m.TotalAmount, new { @class = "form-control", type = "number", step = "0.01" })
                    @Html.ValidationMessageFor(m => m.TotalAmount, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Description</label>
                    @Html.TextBoxFor(m => m.Description, new { @class = "form-control" })
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success fw-bold">
                    <i class="bi bi-save"></i> SAVE
                </button>
                <a href="@Url.Action("Index", "Receivables")" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </div>
    </div>
}
