@model AccountsReceivable.Models.Customer

@{
    ViewBag.Title = "Customer Details";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Customers")">
        <i class="bi bi-arrow-left"></i> BACK
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">Customers</div>
        <h1 class="h3 fw-bold m-0"><span>Details</span> of @Model.Name</h1>
    </div>
    <div style="min-width:140px; text-align:right;">
        <a class="btn btn-success btn-sm fw-bold" href="@Url.Action("Edit", "Customers", new { id = Model.CustomerId })">
            <i class="bi bi-pencil"></i> EDIT
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white">
        <span class="card-header-title"><i class="bi bi-info-circle"></i> Customer Information</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label form-label-sm">Customer Code</label>
                <input class="form-control" value="@Model.CustomerCode" readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label form-label-sm">Name</label>
                <input class="form-control" value="@Model.Name" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">Tax Id</label>
                <input class="form-control" value="@Model.TaxId" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm">Email</label>
                <input class="form-control" value="@Model.Email" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm">Phone</label>
                <input class="form-control" value="@Model.Phone" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm">Credit Limit</label>
                <input class="form-control" value="@String.Format("{0:C}", Model.CreditLimit)" readonly />
            </div>
            <div class="col-md-12">
                <label class="form-label form-label-sm">Address</label>
                <input class="form-control" value="@Model.Address" readonly />
            </div>
        </div>
    </div>
</div>
