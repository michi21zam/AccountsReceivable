@using AccountsReceivable.Resources
@model AccountsReceivable.Models.Customer

@{
    ViewBag.Title = Lang.T("TitleDetailsOf");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Customers")">
        <i class="bi bi-arrow-left"></i> @Lang.T("Back")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">@Lang.T("LabelCustomers")</div>
        <h1 class="h3 fw-bold m-0">@Lang.T("TitleDetailsOf") @Model.Name</h1>
    </div>
    @*<div style="min-width:140px; text-align:right;">
        <a class="btn btn-success btn-sm fw-bold" href="@Url.Action("Edit", "Customers", new { id = Model.CustomerId })">
            <i class="bi bi-pencil"></i> @Lang.T("Edit")
        </a>
    </div>*@
</div>

<div class="card">
    <div class="card-header bg-white">
        <span class="card-header-title"><i class="bi bi-info-circle"></i> @Lang.T("SectionCustomerInfo")</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldCustomerCode")</label>
                <input class="form-control" value="@Model.CustomerCode" readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label form-label-sm">@Lang.T("FieldName")</label>
                <input class="form-control" value="@Model.Name" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldTaxId")</label>
                <input class="form-control" value="@Model.TaxId" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm">@Lang.T("FieldEmail")</label>
                <input class="form-control" value="@Model.Email" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm">@Lang.T("FieldPhone")</label>
                <input class="form-control" value="@Model.Phone" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm">@Lang.T("FieldCreditLimit")</label>
                <input class="form-control" value="@String.Format("{0:C}", Model.CreditLimit)" readonly />
            </div>
            <div class="col-md-12">
                <label class="form-label form-label-sm">@Lang.T("FieldAddress")</label>
                <input class="form-control" value="@Model.Address" readonly />
            </div>
        </div>
    </div>
</div>
