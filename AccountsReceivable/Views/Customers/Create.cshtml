@model AccountsReceivable.Models.Customer

@{
    ViewBag.Title = "Create Customer";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Index", "Customers")">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Customers</div>
        <h1 class="page-title"><span>Create</span> new customer</h1>
    </div>
    <div class="header-spacer"></div>
</div>

@using (Html.BeginForm("Create", "Customers", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-page-card">
        <div class="form-page-header">
            <i class="fa fa-circle-info"></i> Customer Information
        </div>

        @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

        <div class="form-row-grid">
            <div class="float-field">
                <label>Customer Code</label>
                @Html.TextBoxFor(m => m.CustomerCode, new { @class = "float-input", placeholder = " " })
                @Html.ValidationMessageFor(m => m.CustomerCode, "", new { @class = "field-error" })
            </div>
            <div class="float-field grid-span-2">
                <label>Name</label>
                @Html.TextBoxFor(m => m.Name, new { @class = "float-input", placeholder = " " })
                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Tax Id</label>
                @Html.TextBoxFor(m => m.TaxId, new { @class = "float-input", placeholder = " " })
            </div>
            <div class="float-field">
                <label>Email</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "float-input", placeholder = " " })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
            </div>
            <div class="float-field">
                <label>Phone</label>
                @Html.TextBoxFor(m => m.Phone, new { @class = "float-input", placeholder = " " })
            </div>
            <div class="float-field grid-span-2">
                <label>Address</label>
                @Html.TextBoxFor(m => m.Address, new { @class = "float-input", placeholder = " " })
            </div>
            <div class="float-field">
                <label>Credit Limit</label>
                @Html.TextBoxFor(m => m.CreditLimit, new { @class = "float-input", type = "number", step = "0.01", placeholder = " " })
                @Html.ValidationMessageFor(m => m.CreditLimit, "", new { @class = "field-error" })
            </div>
        </div>

        <div class="form-page-actions">
            <button type="submit" class="btn-create">
                <i class="fa fa-floppy-disk"></i> SAVE
            </button>
            <a href="@Url.Action("Index", "Customers")" class="btn-back ml-10">
                Cancel
            </a>
        </div>
    </div>
}
