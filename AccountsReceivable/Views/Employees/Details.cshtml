@model AccountsReceivable.Models.Employee

@{
    ViewBag.Title = "Employee Details";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a class="btn btn-info" href="@Url.Action("Index", "Employees")">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="text-center flex-grow-1">
        <div class="text-muted text-uppercase small fw-bold" style="letter-spacing: 2px;">Employees</div>
        <h1 class="h3 fw-bold"><span style="color: #0b5566;">Details</span> of @Model.FirstName @Model.LastName</h1>
    </div>
    <div>
        <a class="btn btn-success" href="@Url.Action("Edit", "Employees", new { id = Model.EmployeeId })">
            <i class="fa fa-pen"></i> EDIT
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom">
        <h5 class="mb-0 text-uppercase fw-bold" style="color: #0b5566; letter-spacing: 1px; font-size: 13px;">
            <i class="fa fa-circle-info"></i> Employee Information
        </h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Employee Code</label>
                <input class="form-control" value="@Model.EmployeeCode" readonly />
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Full Name</label>
                <input class="form-control" value="@Model.FirstName @Model.LastName" readonly />
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Email</label>
                <input class="form-control" value="@Model.Email" readonly />
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Phone</label>
                <input class="form-control" value="@Model.Phone" readonly />
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Position</label>
                <input class="form-control" value="@Model.Position" readonly />
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Hire Date</label>
                <input class="form-control" value="@Model.HireDate.ToString("MMM dd, yyyy")" readonly />
            </div>
        </div>
    </div>
</div>