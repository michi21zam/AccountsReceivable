@model AccountsReceivable.Models.Employee

@{
    ViewBag.Title = "Delete Employee";
}

<div class="page-header-section">
    <div>
        <a class="btn-back" href="@Url.Action("Index", "Employees")">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Employees</div>
        <h1 class="page-title page-title--danger"><span>Delete</span> employee?</h1>
    </div>
    <div class="header-spacer"></div>
</div>

<div class="form-page-card form-page-card--danger">
    <div class="form-page-header form-page-header--danger">
        <i class="fa fa-triangle-exclamation"></i> Confirm Deletion
    </div>
    <p class="muted-lead">
        Are you sure you want to delete this employee? This action cannot be undone.
    </p>

    <div class="form-row-grid">
        <div class="float-field">
            <label>Employee Code</label>
            <input class="float-input" value="@Model.EmployeeCode" readonly />
        </div>
        <div class="float-field grid-span-2">
            <label>Full Name</label>
            <input class="float-input" value="@Model.FirstName @Model.LastName" readonly />
        </div>
        <div class="float-field">
            <label>Email</label>
            <input class="float-input" value="@Model.Email" readonly />
        </div>
    </div>

    @using (Html.BeginForm("Delete", "Employees", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.EmployeeId)
        <div class="form-page-actions">
            <button type="submit" class="btn-create btn-create--danger">
                <i class="fa fa-trash"></i> YES, DELETE
            </button>
            <a href="@Url.Action("Index", "Employees")" class="btn-back ml-10">
                Cancel
            </a>
        </div>
    }
</div>
