@using AccountsReceivable.Resources
@model AccountsReceivable.Models.Employee

@{
    ViewBag.Title = Lang.T("TitleDeleteEmployee");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Employees")">
        <i class="bi bi-arrow-left"></i> @Lang.T("Back")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label text-danger">@Lang.T("LabelEmployees")</div>
        <h1 class="h3 fw-bold m-0 text-danger">@Lang.T("TitleDeleteEmployee")</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

<div class="card border-top border-danger border-3">
    <div class="card-header bg-white">
        <span class="card-header-title text-danger"><i class="bi bi-exclamation-triangle"></i> @Lang.T("ConfirmDeletion")</span>
    </div>
    <div class="card-body">
        <p class="text-muted mb-4">
            @Lang.T("ConfirmDeleteEmployeeText")
        </p>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label form-label-sm">@Lang.T("FieldEmployeeCode")</label>
                <input class="form-control" value="@Model.EmployeeCode" readonly />
            </div>
            <div class="col-md-5">
                <label class="form-label form-label-sm">@Lang.T("FieldFullName")</label>
                <input class="form-control" value="@Model.FirstName @Model.LastName" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">@Lang.T("FieldEmail")</label>
                <input class="form-control" value="@Model.Email" readonly />
            </div>
        </div>

        @using (Html.BeginForm("Delete", "Employees", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.EmployeeId)
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-danger fw-bold">
                    <i class="bi bi-trash"></i> @Lang.T("YesDelete")
                </button>
                <a href="@Url.Action("Index", "Employees")" class="btn btn-outline-secondary">
                    @Lang.T("Cancel")
                </a>
            </div>
        }
    </div>
</div>
