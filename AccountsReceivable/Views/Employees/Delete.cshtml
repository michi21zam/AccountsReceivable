@model AccountsReceivable.Models.Employee

@{
    ViewBag.Title = "Delete Employee";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Employees")">
        <i class="bi bi-arrow-left"></i> BACK
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label text-danger">Employees</div>
        <h1 class="h3 fw-bold m-0 text-danger"><span>Delete</span> employee?</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

<div class="card border-top border-danger border-3">
    <div class="card-header bg-white">
        <span class="card-header-title text-danger"><i class="bi bi-exclamation-triangle"></i> Confirm Deletion</span>
    </div>
    <div class="card-body">
        <p class="text-muted mb-4">
            Are you sure you want to delete this employee? This action cannot be undone.
        </p>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label form-label-sm">Employee Code</label>
                <input class="form-control" value="@Model.EmployeeCode" readonly />
            </div>
            <div class="col-md-5">
                <label class="form-label form-label-sm">Full Name</label>
                <input class="form-control" value="@Model.FirstName @Model.LastName" readonly />
            </div>
            <div class="col-md-3">
                <label class="form-label form-label-sm">Email</label>
                <input class="form-control" value="@Model.Email" readonly />
            </div>
        </div>

        @using (Html.BeginForm("Delete", "Employees", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.EmployeeId)
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-danger fw-bold">
                    <i class="bi bi-trash"></i> YES, DELETE
                </button>
                <a href="@Url.Action("Index", "Employees")" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        }
    </div>
</div>
