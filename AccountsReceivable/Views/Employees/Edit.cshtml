@model AccountsReceivable.Models.Employee

@{
    ViewBag.Title = "Edit Employee";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a class="btn btn-info" href="@Url.Action("Index", "Employees")">
            <i class="fa fa-arrow-left"></i> BACK
        </a>
    </div>
    <div class="text-center flex-grow-1">
        <div class="text-muted text-uppercase small fw-bold" style="letter-spacing: 2px;">Employees</div>
        <h1 class="h3 fw-bold"><span style="color: #0b5566;">Edit</span> employee</h1>
    </div>
    <div style="min-width: 100px;"></div>
</div>

@using (Html.BeginForm("Edit", "Employees", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.EmployeeId)

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 text-uppercase fw-bold" style="color: #0b5566; letter-spacing: 1px; font-size: 13px;">
                <i class="fa fa-circle-info"></i> Employee Information
            </h5>
        </div>
        <div class="card-body">
            @if (ViewData.ModelState.Count > 0 && !ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @Html.ValidationSummary(false)
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="row g-3">
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Employee Code</label>
                    @Html.TextBoxFor(m => m.EmployeeCode, new { @class = "form-control", placeholder = " " })
                    @Html.ValidationMessageFor(m => m.EmployeeCode, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">First Name</label>
                    @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = " " })
                    @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Last Name</label>
                    @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = " " })
                    @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Email</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = " " })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Phone</label>
                    @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = " " })
                </div>
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Position</label>
                    @Html.TextBoxFor(m => m.Position, new { @class = "form-control", placeholder = " " })
                </div>
                <div class="col-lg-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Hire Date</label>
                    @Html.TextBoxFor(m => m.HireDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.HireDate, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
            </div>
        </div>
        <div class="card-footer bg-white border-top">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="fa fa-floppy-disk"></i> SAVE
                </button>
                <a href="@Url.Action("Index", "Employees")" class="btn btn-secondary">
                    Cancel
                </a>
            </div>
        </div>
    </div>
}