@model AccountsReceivable.Models.Employee

@{
    ViewBag.Title = "Edit Employee";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Employees")">
        <i class="bi bi-arrow-left"></i> BACK
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">Employees</div>
        <h1 class="h3 fw-bold m-0"><span>Edit</span> employee</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

@using (Html.BeginForm("Edit", "Employees", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.EmployeeId)

    <div class="card">
        <div class="card-header bg-white">
            <span class="card-header-title"><i class="bi bi-info-circle"></i> Employee Information</span>
        </div>
        <div class="card-body">

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2" })

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Employee Code</label>
                    @Html.TextBoxFor(m => m.EmployeeCode, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.EmployeeCode, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">First Name</label>
                    @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-5">
                    <label class="form-label form-label-sm">Last Name</label>
                    @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Email</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Phone</label>
                    @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Position</label>
                    @Html.TextBoxFor(m => m.Position, new { @class = "form-control" })
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Hire Date</label>
                    @Html.TextBoxFor(m => m.HireDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.HireDate, "", new { @class = "text-danger small" })
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success fw-bold">
                    <i class="bi bi-save"></i> SAVE
                </button>
                <a href="@Url.Action("Index", "Employees")" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </div>
    </div>
}
