@using AccountsReceivable.Resources
@model AccountsReceivable.Models.Employee

@{
    ViewBag.Title = Lang.T("TitleEditEmployee");
}

@using (Html.BeginForm("Edit", "Employees", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.EmployeeId)

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex gap-2">
            <a class="btn btn-primary fw-bold" href="@Url.Action("Index", "Employees")">
                <i class="bi bi-arrow-left"></i> @Lang.T("Back")
            </a>

            <button type="submit" class="btn btn-success fw-bold">
                <i class="bi bi-save"></i> @Lang.T("Save")
            </button>
        </div>

        <div class="text-center flex-grow-1">
            <div class="page-label">@Lang.T("LabelEmployees")</div>
            <h1 class="h3 fw-bold m-0">@Lang.T("TitleEditEmployee")</h1>
        </div>

        <div style="min-width:140px;"></div>
    </div>

    <div class="card">
        <div class="card-header bg-white">
            <span class="card-header-title">
                <i class="bi bi-info-circle"></i> @Lang.T("SectionEmployeeInfo")
            </span>
        </div>

        <div class="card-body">

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2" })

            <div class="row g-3">

                <div class="col-md-3">
                    <label class="form-label form-label-sm">@Lang.T("FieldEmployeeCode")</label>
                    @Html.TextBoxFor(m => m.EmployeeCode, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.EmployeeCode, "", new { @class = "text-danger small" })
                </div>

                <div class="col-md-4">
                    <label class="form-label form-label-sm">@Lang.T("FieldFirstName")</label>
                    @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger small" })
                </div>

                <div class="col-md-5">
                    <label class="form-label form-label-sm">@Lang.T("FieldLastName")</label>
                    @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger small" })
                </div>

                <div class="col-md-4">
                    <label class="form-label form-label-sm">@Lang.T("FieldEmail")</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>

                <div class="col-md-4">
                    <label class="form-label form-label-sm">@Lang.T("FieldPhone")</label>
                    @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
                </div>

                <div class="col-md-4">
                    <label class="form-label form-label-sm">@Lang.T("FieldPosition")</label>
                    @Html.TextBoxFor(m => m.Position, new { @class = "form-control" })
                </div>

                <div class="col-md-4">
                    <label class="form-label form-label-sm">@Lang.T("FieldHireDate")</label>
                    @Html.TextBoxFor(m => m.HireDate, "{0:yyyy-MM-dd}", new
                    {
                        @class = "form-control",
                        type = "date"
                    })
                    @Html.ValidationMessageFor(m => m.HireDate, "", new { @class = "text-danger small" })
                </div>

            </div>

        </div>
    </div>
}