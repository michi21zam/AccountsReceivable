@using AccountsReceivable.Resources
@model IEnumerable<AccountsReceivable.Models.Employee>

@{
    ViewBag.Title = Lang.T("NavEmployees");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a class="btn btn-success fw-bold" href="@Url.Action("Create", "Employees")">
        <i class="bi bi-plus-lg"></i> @Lang.T("CreateNew")
    </a>
    <div class="text-center flex-grow-1">
        <div class="page-label">@Lang.T("LabelEmployees")</div>
        <h1 class="h3 fw-bold m-0">@Lang.T("TitleManageEmployees")</h1>
    </div>
    <div style="min-width:140px;"></div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>@Lang.T("ColCode")</th>
                    <th>@Lang.T("FieldName")</th>
                    <th>@Lang.T("FieldEmail")</th>
                    <th>@Lang.T("FieldPhone")</th>
                    <th>@Lang.T("FieldPosition")</th>
                    <th>@Lang.T("FieldHireDate")</th>
                    <th class="text-center">@Lang.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.EmployeeCode</td>
                            <td>@item.FirstName @item.LastName</td>
                            <td>@item.Email</td>
                            <td>@item.Phone</td>
                            <td>@item.Position</td>
                            <td>@item.HireDate.ToString("MMM dd, yyyy")</td>
                            <td class="text-center">
                                <a class="btn btn-primary btn-action" href="@Url.Action("Details", "Employees", new { id = item.EmployeeId })" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a class="btn btn-warning btn-action" href="@Url.Action("Edit", "Employees", new { id = item.EmployeeId })" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @using (Html.BeginForm("Delete", "Employees", FormMethod.Post,
                                    new { @class = "d-inline", onsubmit = "return confirm('" + Lang.T("ConfirmDeleteEmployeeJs") + "');" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", item.EmployeeId)
                                    <button type="submit" class="btn btn-danger btn-action" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-person-badge d-block fs-1 opacity-25 mb-2"></i>
                            @Lang.T("NoEmployeesFound")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>