@model IEnumerable<AccountsReceivable.Models.Employee>

@{
    ViewBag.Title = "Employees";
}

<div class="page-header-section">
    <div>
        <a class="btn-create" href="@Url.Action("Create", "Employees")">
            <i class="fa fa-plus"></i> CREATE NEW
        </a>
    </div>
    <div class="page-header-titles">
        <div class="page-label">Employees</div>
        <h1 class="page-title"><span>Manage</span> employees</h1>
    </div>
    <div class="header-spacer"></div>
</div>

<div class="table-card">
    <table>
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Position</th>
                <th>Hire Date</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.EmployeeCode</td>
                        <td>@item.FirstName @item.LastName</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.Position</td>
                        <td>@item.HireDate.ToString("MMM dd, yyyy")</td>
                        <td class="text-center">
                            <a class="action-btn action-view" href="@Url.Action("Details", "Employees", new { id = item.EmployeeId })" title="Details">
                                <i class="fa fa-eye"></i>
                            </a>
                            <a class="action-btn action-edit" href="@Url.Action("Edit", "Employees", new { id = item.EmployeeId })" title="Edit">
                                <i class="fa fa-pen"></i>
                            </a>
                            @using (Html.BeginForm("Delete", "Employees", FormMethod.Post,
                                new { @class = "inline-form", onsubmit = "return confirm('Delete this employee?');" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("id", item.EmployeeId)
                                <button type="submit" class="action-btn action-delete" title="Delete">
                                    <i class="fa fa-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="no-data-cell">
                        <i class="fa fa-user-tie no-data-icon"></i>
                        No employees found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
